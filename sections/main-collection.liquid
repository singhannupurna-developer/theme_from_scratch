<script src="{{ 'collection-filter.js' | asset_url }}" defer></script>
<style>
    .collection-page {
      max-width: 1200px;
      margin: auto;
      padding: 60px 20px;
    }
    .collection-filters {
      padding: 20px;
      box-shadow: 0px 0px 2px rgba(0, 0, 0, 0.4);
      border-radius: 10px;
    }
    .collection-filter__heading h2 {
      font-weight: 600;
      color: #000;
      font-size: 30px;
      margin-bottom: 30px;
    }
    .collection-filter__label {
      color: #000;
      font-weight: 600;
      font-size: 18px;
      margin-bottom: 6px;
    }
    .collection-section {
      display: flex;
      gap: 30px;
    }
    .collection-filters {
      width: 20%;
    }
    .collection-title {
      font-size: 36px;
      font-weight: 700;
      margin-bottom: 40px;
      text-align: center;
    }
    .collection-filter-section {
      margin-bottom: 10px;
    }

    .collection-grid {
      width: 80%;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
    }

    .collection-product {
      text-align: center;
    }
    .product-image{
      height: 250px;
      object-fit: contain;
      border-radius:8px;
    }
    .product-image img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      border-radius:8px;
    }

    .product-title {
      font-size: 18px;
      margin-top: 15px;
    }

    .product-price {
      font-weight: 600;
      margin-top: 8px;
    }
    .custom-add-to-cart {
      padding: 14px 32px;
      background: #000;
      color: #fff;
      border: none;
      cursor: pointer;
      font-size: 16px;
      border-radius:8px;
      width:100%;
  }
    .collection-product a {
      text-decoration: none;
      color: #000;
    }

    .collection-product:hover {
      transform: translateY(-5px);
      transition: 0.2s ease;
    }
    .collection-filter--active__values {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 20px;
    }
    .filter-cross-btn{
      font-size:7px;
    }
    .collection-filters__active-filter-swatch{
      background: #000;
      padding: 10px 15px;
      color: #fff;
      border-radius: 20px;
      cursor:pointer;
    }
    .collection-filter__option{
     display:flex;
     flex-wrap:wrap;
     {% comment %} flex-direction:column; {% endcomment %}
     gap:5px;
     {% comment %} padding-left:10px; {% endcomment %}
    }
    .collection-filter__swatch{
      display:flex;
      {% comment %} flex-direction:column; {% endcomment %}
      gap:5px;
      align-items:center;
    }
    .collection-filter__swatch input{
     display:none;
    }
    .collection-filter__swatch label{
      padding:5px 10px;
      border-radius:4px;
      border:1px solid #000;
      cursor:pointer;

    }
    .collection-filter__swatch-color{
       padding:5px;
      border-radius:500px;
    }
    .collection-filter__swatch-color label{
        height: 100%;
        border-radius: 500px;
    }
    .collection-filter__swatch input:checked + label{
      background:#000;
      color:#fff;
    }
    .accordion__content {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-in-out;
    }

    .accordion--open .accordion__content {
      max-height: var(--accordion-content-height); /* Uses the calculated height */
    }

    .accordion__header {
      cursor: pointer;
    }

    .accordion__toggle-icon {
      transform: rotate(0deg);
      transition: transform 0.3s ease;
    }

    .accordion--open .accordion__toggle-icon {
      transform: rotate(180deg); /* Rotate the icon when open */
    }
    @media (max-width: 900px) {
      .collection-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 600px) {
      .collection-grid {
        grid-template-columns: 1fr;
      }
    }
</style>

<div class="collection-page">
  <!-- COLLECTION TITLE -->
  <h1 class="collection-title">
    {{ collection.title }}
  </h1>

  <!-- PRODUCT GRID -->
  <div class="collection-section">
    <collection-filters class="collection-filters" data-section-id="{{ section.id }}">
      <div class="collection-filter__heading">
        <h2>Filters</h2>
      </div>
      <div class="collection-filter--active__values">
        {% for filter in collection.filters %}
          {% for value in filter.active_values %}
            <div class="collection-filters__active-filter-swatch">
              <input
                data-remove-url="{{ value.url_to_remove }}"
                type="hidden"
                name="{{ filter.label | handle }}"
                value="{{ value.value | handle }}"
              >
              <label
                for="{{ filter.label | handle }}-{{ value.value | handle }}"
                class="collection-filters__active-filter-swatch-label"
              >
                {{- value.label }}
                <span class="filter-cross-btn">X</span></label
              >
            </div>
          {% endfor %}
        {% endfor %}
      </div>
      <div class="collection-filter__content">
        {% for filter in collection.filters %}
          <div class="collection-filter-section">
            <accordion-toggle class="accordion">
              <div class="accordion__header collection-filter__label">
                <span class="accordion__header-label">{{ filter.label }}</span>
                <span class="accordion__toggle-icon">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12.5 6.5L8 11L3.5 6.5" stroke="black" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </span>
              </div>
              <div class="accordion__content">
                <div class="collection-filter__option">
                  {% if filter.type == 'list' or filter.type == 'boolean' %}
                    {% for value in filter.values %}
                      {% if filter.label == 'Color' %}
                        <div class="collection-filter__options collection-filter__swatch collection-filter__swatch-color">
                          <input
                            type="checkbox"
                            id="{{ filter.label | handle }}-{{ value.value | handle }}"
                            name="{{ filter.label | handle }}"
                            value="{{ filter.value | handle }}"
                            data-add-url="{{ value.url_to_add }}"
                            data-remove-url="{{ value.url_to_remove }}"
                            {% if value.active %}
                              checked
                            {% endif %}
                          >
                          <label
                            for="{{ filter.label | handle }}-{{ value.value | handle}}"
                            {% if value.swatch.color %}
                              style="background-color: {{ value.swatch.color }};"
                            {% elsif value.swatch.image %}
                              style="background-image: url({{ value.swatch.image | image_url : width : 100 }});"
                            {% else %}
                              style="background-color:{{ value.label }};"
                            {% endif %}
                          >
                            {% comment %} {{ value.label }} {% endcomment %}
                          </label>
                        </div>
                      {% else %}
                        <div class="collection-filter__options collection-filter__swatch">
                          <input
                            type="checkbox"
                            id="{{ filter.label | handle }}-{{ value.value | handle }}"
                            name="{{ filter.label | handle }}"
                            value="{{ filter.value | handle }}"
                            data-add-url="{{ value.url_to_add }}"
                            data-remove-url="{{ value.url_to_remove }}"
                            {% if value.active %}
                              checked
                            {% endif %}
                          >
                          <label
                            for="{{ filter.label | handle }}-{{ value.value | handle}}"
                          >
                            {{ value.label }}
                          </label>
                        </div>
                      {% endif %}
                    {% endfor %}
                  {% else %}
                    <div class="collection-filter__options">
                      <div class="collection-filter__price-range">
                        {% if filter.min_value.value %}
                          {% assign min_value = filter.min_value.value | divided_by: 100.0 %}
                        {% else %}
                          {% assign min_value = 0.0 %}
                        {% endif %}
                        <input
                          type="range"
                          id="{{ filter.min_value.param_name }}"
                          name="{{ filter.min_value.param_name }}"
                          min="0"
                          max="{{ filter.range_max }}"
                          value="{{ min_value | divided_by:100 | round | plus:1 }}"
                          {% if filter.min_value.value %}
                            value="{{ filter.min_value.value }}"
                          {% else %}
                            value="0"
                          {% endif %}
                          data-param="{{ filter.min_value.param_name }}"
                          data-min-value
                        >
                        {% if filter.max_value.value %}
                          {% assign max_value = filter.max_value.value | divided_by: 100.0 %}
                        {% else %}
                          {% assign max_value = filter.range_max | divided_by: 100.0 %}
                        {% endif %}
                        <input
                          type="range"
                          id="{{ filter.max_value.param_name }}"
                          name="{{ filter.max_value.param_name }}"
                          min="0"
                          max="{{ filter.range_max | divided_by:100 | round | plus: 1 }}"
                          value="{{ max_value }}"
                          data-param="{{ filter.max_value.param_name }}"
                          data-max-value
                        >
                      </div>
                    </div>
                  {% endif %}
                </div>
              </div>
            </accordion-toggle>
          </div>
        {% endfor %}
      </div>
    </collection-filters>
    <div class="collection-grid">
      {% for product in collection.products %}
        <div class="collection-product">
          <a href="{{ product.url }}">
            <div class="product-image">
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.title }}"
              >
            </div>

            <h3 class="product-title">
              {{ product.title }}
            </h3>

            <p class="product-price">
              {{ product.price | money }}
            </p>
            {% form 'product', product %}
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <button class="custom-add-to-cart">Add to Cart</button>
            {% endform %}
          </a>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Main Collection"
}
{% endschema %}
