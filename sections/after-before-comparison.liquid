<style>
    /* Image Comparison Styles */
    .image-comparison {
      width: 100%;
      position: relative;
      text-align: center;
    }

    .container {
      width: 90%;
      margin: 0 auto;
    }

    .section-title {
      font-size: 2rem;
      margin-bottom: 10px;
    }

    .section-content {
      font-size: 1rem;
      margin-bottom: 30px;
    }

    .comparison-container {
      display: flex;
      gap: 20px;
      position: relative;
      aspect-ratio:16/9;
    }

    .comparison-block {
      position: relative;
      width: 100%;
      max-width: 600px;
      height:100%;
    }

    .before-image{
      position: absolute;
      width: 100%;
      height: 100%;
      top: 0;
      left: 0;
    }
    .after-image {
      position: absolute;
      width: 100%;
      height: 100%;
      top: 0;
      right: 0;
    }

    .before-image img,
    .after-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .before-label{
      position: absolute;
      top: 10px;
      left: 10px;
      font-size: 1.2rem;
      color: #fff;
      font-weight: bold;
    }
    .after-label {
      position: absolute;
      top: 10px;
      right: 10px;
      font-size: 1.2rem;
      color: #fff;
      font-weight: bold;
    }

    .slider {
      position: absolute;
      top: 50%;
      left: 50%;
      width: 50px;
      height: 50px;
      background-color: #fff;
      cursor: ew-resize;
      z-index: 10;
      border-radius: 50%;
  }

    .slider:active {
      cursor: grabbing;
    }

    .slider::before {
      content: '←'; /* Arrow symbol */
      color: #000;
      font-size: 24px;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
    }

    .comparison-block .before-image {
      transition: width 0.3s ease; /* Smooth transition for width change */
      z-index: 2; /* Ensure before image is on top */
    }

    .comparison-block .after-image {
      transition: width 0.3s ease;
      z-index: 1; /* Ensure after image stays behind */
    }
</style>

<section class="image-comparison">
  <div class="container">
    <h2 class="section-title">{{ section.settings.section_title }}</h2>
    <p class="section-content">{{ section.settings.section_content }}</p>

    <div class="comparison-container">
      {% for block in section.blocks %}
        <div class="comparison-block">
          <div class="before-image">
            <img src="{{ block.settings.before_image | image_url: width: 900 }}" alt="Before Image">
            <span class="label before-label">{{ block.settings.before_label }}</span>
          </div>
          <div class="after-image">
            <img src="{{ block.settings.after_image | image_url: width: 900 }}" alt="After Image">
            <span class="label after-label">{{ block.settings.after_label }}</span>
          </div>
          <div class="slider"></div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Before & After Comparison",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Before & After Comparison"
    },
    {
      "type": "textarea",
      "id": "section_content",
      "label": "Section Content",
      "default": "Move the slider to compare the before and after images."
    }
  ],
  "blocks": [
    {
      "type": "comparison",
      "name": "Before / After Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "before_image",
          "label": "Before Image"
        },
        {
          "type": "image_picker",
          "id": "after_image",
          "label": "After Image"
        },
        {
          "type": "text",
          "id": "before_label",
          "label": "Before Label",
          "default": "Before"
        },
        {
          "type": "text",
          "id": "after_label",
          "label": "After Label",
          "default": "After"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Image Comparison Preset",
      "blocks": [{ "type": "comparison" }, { "type": "comparison" }, { "type": "comparison" }]
    }
  ]
}
{% endschema %}
{% comment %}
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.comparison-container').forEach((container) => {
        const slider = container.querySelector('.slider');
        const beforeImg = container.querySelector('.before-image img');
        const afterImg = container.querySelector('.after-image img');
        const beforeLabel = container.querySelector('.before-label');
        const afterLabel = container.querySelector('.after-label');

        let sliderPosition = 50; // Start at 50% width for before image
        beforeImg.style.clipPath = `inset(0 0 0 ${sliderPosition}%)`; // Initial clip for before image
        afterImg.style.clipPath = `inset(0 ${100 - sliderPosition}% 0 0)`; // Initial clip for after image
        slider.style.left = `${sliderPosition}%`; // Position the slider handle at 50%

        const updateUI = (value) => {
          beforeImg.style.clipPath = `inset(0 0 0 ${value}%)`;
          afterImg.style.clipPath = `inset(0 ${100 - value}% 0 0)`;
          slider.style.left = `${value}%`;
        };

        slider.addEventListener('mousedown', (e) => {
          e.preventDefault();
          const initialX = e.clientX;

          const mouseMoveHandler = (moveEvent) => {
            const dx = moveEvent.clientX - initialX;
            sliderPosition = Math.min(Math.max(0, ((sliderPosition + dx) / container.offsetWidth) * 100), 100);
            updateUI(sliderPosition);
          };

          const mouseUpHandler = () => {
            window.removeEventListener('mousemove', mouseMoveHandler);
            window.removeEventListener('mouseup', mouseUpHandler);
          };

          window.addEventListener('mousemove', mouseMoveHandler);
          window.addEventListener('mouseup', mouseUpHandler);
        });
      });
    });
  </script>
