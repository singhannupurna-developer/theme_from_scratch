<style>

.featured-collections{
  padding:60px 20px;
}

.featured-collections-container{
  max-width:1200px;
  margin:auto;
}

.featured-collections-title{
  text-align:center;
  font-size:32px;
  margin-bottom:40px;
}

.featured-collections-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:30px;
}

.featured-collection-card{
  text-decoration:none;
  color:#000;
}

.featured-collection-image img{
  width:100%;
  height:260px;
  object-fit:cover;
}

.featured-collection-name{
  margin-top:12px;
  font-size:18px;
  text-align:center;
}

.featured-collection-card:hover{
  transform:translateY(-5px);
  transition:0.25s ease;
}

@media(max-width:900px){
.featured-collections-grid{
  grid-template-columns:repeat(2,1fr);
}
}

@media(max-width:500px){
.featured-collections-grid{
  grid-template-columns:1fr;
}
}

</style>

<section class="featured-collections">

  <div class="featured-collections-container">

    {% if section.settings.heading != blank %}
      <h2 class="featured-collections-title">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="featured-collections-grid">

      {% for block in section.blocks %}
        {% assign collection = block.settings.collection %}

        {% if collection != blank %}
        <a href="{{ collection.url }}" class="featured-collection-card">

          <div class="featured-collection-image">
            {% if collection.featured_image %}
              <img 
                src="{{ collection.featured_image | image_url: width: 800 }}" 
                alt="{{ collection.title }}"
              >
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag }}
            {% endif %}
          </div>

          <h3 class="featured-collection-name">
            {{ collection.title }}
          </h3>

        </a>
        {% endif %}

      {% endfor %}

    </div>

  </div>

</section>

{% schema %}
{
  "name": "Featured Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Featured Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Featured Collections",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}