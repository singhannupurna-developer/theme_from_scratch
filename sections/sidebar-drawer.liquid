<side-drawer id="sideDrawer">
    {% comment %} <template id="side-cart-item">
      {% render 'side-cart-item' %}
    </template> {% endcomment %}
    <div slot="content">
      <h2>{{ 'sections.cart.title' | t }}</h2>
      {% for item in cart.items %}
        {% render 'side-cart-item', item: item %}
      {% endfor %}
    </div> 
</side-drawer>



<script>
  class SideDrawer extends HTMLElement {
    constructor() {
      super();

      this.attachShadow({ mode: 'open' });

      this.shadowRoot.innerHTML = `
      <style>
        :host {
          position: fixed;
          inset: 0;
          pointer-events: none;
          z-index: 9999;
        }

        .overlay {
          position: absolute;
          inset: 0;
          background: rgba(0,0,0,0.4);
          opacity: 0;
          transition: opacity .25s ease;
        }

        .drawer {
          position: absolute;
          right: 0;
          top: 0;
          height: 100%;
          width: 550px;
          background: #fff;
          transform: translateX(100%);
          transition: transform .3s ease;
          box-shadow: -10px 0 30px rgba(0,0,0,.15);
          overflow: auto;
        }

        :host(.open) {
          pointer-events: auto;
        }

        :host(.open) .overlay {
          opacity: 1;
        }

        :host(.open) .drawer {
          transform: translateX(0);
        }
      </style>

      <div class="overlay"></div>

      <div class="drawer">
        <slot name="content"></slot>
      </div>
    `;

      document.getElementById('header-cart-icon')?.addEventListener('click', (evt) => {
        evt.preventDefault();

        if (this.isOpen()) {
          this.close();
        } else {
          this.open();
        }
      });
    }

    connectedCallback() {
      this.shadowRoot.querySelector('.overlay').addEventListener('click', () => this.close());

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') this.close();
      });
    }

    isOpen() {
      return this.classList.contains('open');
    }

    open() {
      this.classList.add('open');
    }

    close() {
      this.classList.remove('open');
    }
  }

  customElements.define('side-drawer', SideDrawer);
</script>

{% schema %}
{
  "name": "Sidebar",
  "settings": [],
  "presets": [
    {
      "name": "Sidebar"
    }
  ]
}
{% endschema %}
