<script>
  const button = document.querySelector('[data-render]');

  button.addEventListener('click', () => {
    {% comment %} fetch(`${window.Shopify.routes.root}?sections=hello-world,product-list`)
      .then((response) => response.json())
      .then((data) => {
        console.log(data);

        const container = document.querySelector('.basic-render');
        container.innerHTML = ''; // clear first

        // 👉 HELLO WORLD SECTION
        if (data["hello-world"]) {
          const div1 = document.createElement('div');
          div1.innerHTML = data["hello-world"];
          container.appendChild(div1);
        }

        // 👉 PRODUCT LIST SECTION
        if (data["product-list"]) {
          const div2 = document.createElement('div');
          div2.innerHTML = data["product-list"];
          container.appendChild(div2);
        }
      })
      .catch((err) => console.error(err));
  }); {% endcomment %}
    fetch(`${window.Shopify.routes.root}/products/test-1?section=product`)
      .then((res) => res.json())
      .then((data) => {
        document.querySelector('.basic-render').innerHTML =
          data["product"];
      });
  });
</script>

