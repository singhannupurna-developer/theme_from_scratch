{% assign tag = block.settings.tag | default: 'p' %}

<{{ tag }} {{ block.shopify_attributes }}>
  {{ block.settings.text }}
</{{ tag }}>

{% schema %}
{
  "name": "Text",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "select",
      "id": "tag",
      "label": "HTML Tag",
      "default": "p",
      "options": [
        { "value": "p", "label": "Paragraph" },
        { "value": "h1", "label": "Heading 1" },
        { "value": "h2", "label": "Heading 2" },
        { "value": "h3", "label": "Heading 3" },
        { "value": "span", "label": "Span" },
        { "value": "div", "label": "Div" }
      ]
    }
  ]
}
{% endschema %}